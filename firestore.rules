rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /special_days/{eventId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email.toLowerCase() == "biswajitnaskar668@gmail.com";
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
